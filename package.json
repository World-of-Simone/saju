{
  "name": "saju-engine",
  "version": "0.1.0",
  "description": "Accurate Saju (Korean Four Pillars) calculation engine with true solar time",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "dev:web": "npm run build && vite",
    "build:web": "npm run build && vite build",
    "preview:web": "vite preview"
  },
  "keywords": [
    "saju",
    "four-pillars",
    "korean-astrology",
    "true-solar-time"
  ],
  "license": "MIT",
  "dependencies": {
    "@clerk/clerk-js": "^6.25.0",
    "luxon": "^3.5.0"
  },
  "devDependencies": {
    "@types/luxon": "^3.4.2",
    "typescript": "^5.6.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0"
  }
}
